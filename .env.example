DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/govcrm
DIRECT_URL=postgresql://postgres:postgres@127.0.0.1:5432/govcrm
# Optional for hosted Postgres when prisma migrate dev needs a dedicated shadow database.
# SHADOW_DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:5432/govcrm_shadow
SESSION_SECRET=change-me-to-a-long-random-secret

# Redis cache
# Option 1: Local Redis
REDIS_URL=redis://127.0.0.1:6379

# Option 2: Upstash / Redis REST
# REDIS_REST_URL=https://your-redis-endpoint.upstash.io
# REDIS_REST_TOKEN=your-redis-rest-token
